{
  "schemaVersion": 1,
  "id": "fastactions",
  "version": "${version}",
  "name": "Quick Menu",
  "description": "Adds a configurable menu to run commands and keybinds.",
  "authors": [
    {
      "name": "Tehbeard",
      "contact": {
        "homepage": "https://tehbeard.com"
      }
    },
    {
      "name": "codist (Original mod)",
      "contact": {
        "homepage": "https://imcodist.xyz"
      }
    }
  ],
  "contact": {
    "homepage": "https://github.com/tehbeard/quick-menu",
    "sources": "https://github.com/tehbeard/quick-menu",
    "issues": "https://github.com/tehbeard/quick-menu/issues"
  },
  "license": "GNU-3.0",
  "icon": "assets/fastactions/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.tehbeard.fabric.fastaction.FastAction"
    ]
  },
  "mixins": [
    "quickmenu.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": [
      "26.1.*"
    ],
    "java": ">=25",
    "fabric-api": "*"
  }
}